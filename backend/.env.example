APP_ENV=development
APP_PORT=8080

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pos_gym

# Ganti untuk production. Minimal 32 karakter disarankan.
JWT_SECRET=change-this-local-secret-before-production
JWT_TTL_HOURS=24

# Untuk Flutter web lokal, contoh:
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8088
CORS_ALLOWED_ORIGINS=*
