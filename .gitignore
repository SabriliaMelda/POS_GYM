# ==== POS_GYM monorepo ====
# Struktur: frontend/ (Flutter), backend/ (Go), module/ (SQL & dokumentasi).

# Backend (Go) — environment & binari hasil build
backend/.env
backend/api
backend/api.exe
backend/*.exe

# Frontend (Flutter) — artefak generate
frontend/.dart_tool/
frontend/build/
frontend/.flutter-plugins-dependencies
frontend/.flutter-plugins
frontend/android/app/debug
frontend/android/app/profile
frontend/android/app/release

# OS / editor
.DS_Store
*.log
*.swp
